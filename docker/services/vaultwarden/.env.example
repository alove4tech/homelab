# Vaultwarden environment
# Copy to .env and fill in your values

# Public URL (required for WebSocket, email, and attachments)
DOMAIN=https://vault.example.com

# Host port for the web UI. Keep this at 80 if Vaultwarden is the only
# service listening on HTTP, or change it when using a reverse proxy.
VAULTWARDEN_PORT=80

# Admin panel token — generate with: openssl rand -base64 48
# Replace the placeholder before deploying.
ADMIN_TOKEN=replace-with-a-long-random-token

# Allow new signups only during initial account creation, then set to false.
SIGNUPS_ALLOWED=true

# Email settings (optional — enable for 2FA, invitations, verifications)
# SMTP_HOST=smtp.example.com
# SMTP_FROM=vaultwarden@example.com
# SMTP_PORT=587
# SMTP_SECURITY=starttls
# SMTP_USERNAME=
# SMTP_PASSWORD=
