# Vaultwarden Environment Variables
# Copy this file to .env and update with your values
# DO NOT commit .env to git!

# ==============================================================================
# REQUIRED SETTINGS
# ==============================================================================

# Domain (required) - Your public-facing domain
DOMAIN=https://vaultwarden.yourdomain.com

# Admin Token (required) - Generate with: openssl rand -base64 48
ADMIN_TOKEN=your_secure_random_token_here

# ==============================================================================
# REGISTRATION
# ==============================================================================

# Allow new user signups (set to false after creating your account)
SIGNUPS_ALLOWED=true

# Sign-up verification settings
SIGNUPS_VERIFY_RESEND_TIME=3600
SIGNUPS_VERIFY_RESEND_LIMIT=5

# ==============================================================================
# DATABASE
# ==============================================================================

# SQLite (default)
DATABASE_URL=/data/db.sqlite3

# To use PostgreSQL instead, uncomment and configure:
# DATABASE_URL=postgresql://user:password@host:5432/vaultwarden

# ==============================================================================
# WEBSOCKET
# ==============================================================================
# NOTE: Since Vaultwarden 1.29+, WebSocket is built into the main HTTP server.
# The separate WebSocket port (3012) and the variables below are no longer
# needed. Kept here for reference if running an older version.
# ==============================================================================

# WEBSOCKET_ENABLED=true
# WEBSOCKET_ADDRESS=0.0.0.0
# WEBSOCKET_PORT=3012

# ==============================================================================
# EMAIL CONFIGURATION (required for password reset and invites)
# ==============================================================================

# Example for Gmail (use App Password, not your regular password)
# SMTP_HOST=smtp.gmail.com
# SMTP_FROM=vaultwarden@yourdomain.com
# SMTP_PORT=587
# SMTP_SECURITY=starttls
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# ==============================================================================
# ATTACHMENTS
# ==============================================================================

ATTACHMENTS_SIZE_LIMIT=104857600
ATTACHMENTS_FOLDER=/data/attachments

# ==============================================================================
# ICON SERVICE
# ==============================================================================

ICON_DOWNLOAD_TIMEOUT=10

# ==============================================================================
# LOGGING
# ==============================================================================

LOG_LEVEL=info
EXTENDED_LOGGING=true
LOG_TIMESTAMP_FORMAT="%Y-%m-%d %H:%M:%S.%3f"

# ==============================================================================
# PERFORMANCE (Pi 400 tuning)
# ==============================================================================

# Number of worker threads (2 is good for Pi 400)
ROCKET_WORKERS=2

# ==============================================================================
# SECURITY
# ==============================================================================

ROCKET_ADDRESS=0.0.0.0
ROCKET_PORT=80

# ==============================================================================
# ADMIN PANEL (RATE LIMITING)
# ==============================================================================

ADMIN_RATELIMIT_SECONDS=60
ADMIN_RATELIMIT_MAX_BURST=10
