# Stirling PDF environment
# Copy to .env and fill in your values

# Host port for the web UI
STIRLINGPDF_PORT=8480

# Security — set to true and configure credentials below to enable login protection
DOCKER_ENABLE_SECURITY=false
SECURITY_ENABLE_LOGIN=false

# Admin credentials (required when DOCKER_ENABLE_SECURITY=true)
# SECURITY_INITIAL_LOGIN_USERNAME=admin
# SECURITY_INITIAL_LOGIN_PASSWORD=***

# Maximum upload file size in MB
# STIRLINGPDF_MAX_FILE_SIZE=100

# Application name shown in the UI
# STIRLINGPDF_APP_NAME=Stirling PDF
