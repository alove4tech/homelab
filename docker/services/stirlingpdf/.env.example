# Stirling PDF configuration
# Copy this file to .env and uncomment/customize as needed.
# By default Stirling PDF runs without authentication.

# ==============================================================================
# SECURITY
# ==============================================================================

# Enable login authentication
# DOCKER_ENABLE_SECURITY=true
# SECURITY_ENABLE_LOGIN=true

# ==============================================================================
# SYSTEM
# ==============================================================================

# Max file upload size in MB
# SYSTEM_MAXFILESIZE=100

# App display name
# UI_APPNAME=Stirling PDF

# ==============================================================================
# ADVANCED
# ==============================================================================

# Custom OCR tessdata path (defaults to built-in)
# INSTALL_BOOK_AND_ADVANCED_HTML_OPS=true

# Locale (en, de, fr, etc.)
# SYSTEM_DEFAULT_LOCALE=en-US
