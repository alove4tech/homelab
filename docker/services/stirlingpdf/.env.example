# Stirling PDF environment
# Copy to .env to override defaults

# Enable login protection (also set DOCKER_ENABLE_SECURITY=true in docker-compose.yml)
# DOCKER_ENABLE_SECURITY=true
# SECURITY_ENABLE_LOGIN=true

# Admin credentials (only used when security is enabled)
# SECURITY_INITIAL_LOGIN_USERNAME=admin
# SECURITY_INITIAL_LOGIN_PASSWORD=
